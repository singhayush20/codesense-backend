{
  "name": "codesense_backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env ENVIRONMENT=dev nest start",
    "start:debug": "cross-env ENVIRONMENT=dev nest start --debug",
    "start:prod": "cross-env ENVIRONMENT=prod node dist/main.js",
    "start:local": "cross-env ENVIRONMENT=local node dist/main.js",
    "start:test": "cross-env ENVIRONMENT=test nest start --debug",
    "start:dev:full": "npm run migration:run && npm run start:dev",
    "start:debug:full": "npm run migration:run && npm run start:debug",
    "start:prod:full": "npm run build && npm run migration:run && npm run start:prod",
    "start:test:full": "npm run migration:run && npm run start:test",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs -d src/config/typeorm.datasource.ts",
    "migration:generate": "npm run typeorm -- migration:generate -p",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:run:prod": "cross-env ENVIRONMENT=prod npm run migration:run",
    "migration:run:dev": "cross-env ENVIRONMENT=dev npm run migration:run",
    "migration:run:test": "cross-env ENVIRONMENT=test npm run migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:revert:prod": "cross-env ENVIRONMENT=prod npm run migration:revert",
    "migration:revert:dev": "cross-env ENVIRONMENT=dev npm run migration:revert",
    "migration:revert:test": "cross-env ENVIRONMENT=test npm run migration:revert",
    "prepare": "husky install"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "ai": "^6.0.191",
    "ai-sdk-ollama": "^3.8.4",
    "axios": "^1.15.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "nestjs-cls": "^6.2.0",
    "nestjs-pino": "^4.6.1",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tree-sitter-wasms": "^0.1.13",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "husky": "^8.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}